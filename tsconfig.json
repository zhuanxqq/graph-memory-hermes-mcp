{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "mcp-server.ts", "scripts/**/*.ts"],
  "exclude": ["test/**/*.ts", "dist", "node_modules"]
}
